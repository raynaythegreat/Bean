// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================
// User & Authentication
// ===========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // Hashed password for credentials auth
  image         String?
  timezone      String    @default("UTC")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      SocialAccount[]
  posts         Post[]
  templates     Template[]
  media         Media[]
  settings      UserSettings?
  sessions      Session[]
  authAccounts  AuthAccount[]

  @@map("users")
}

model UserSettings {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // AI Settings
  defaultAiProvider    String?  // openai, ollama, zhipu, anthropic
  openaiApiKey         String?
  openaiModel          String   @default("gpt-4")
  ollamaEnabled        Boolean  @default(false)
  ollamaBaseUrl        String   @default("http://localhost:11434")
  ollamaModel          String   @default("llama3")
  zhipuApiKey          String?
  zhipuModel           String   @default("glm-4")
  anthropicApiKey      String?
  anthropicModel       String   @default("claude-3-opus-20240229")
  
  // Notification Settings
  notifyScheduledPost  Boolean  @default(true)
  notifyFailedPost     Boolean  @default(true)
  notifyAnalytics      Boolean  @default(false)
  
  // UI Preferences
  theme                String   @default("system") // light, dark, system
  calendarView         String   @default("month") // month, week
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@map("user_settings")
}

// NextAuth models
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ===========================================
// Social Accounts
// ===========================================

enum SocialPlatform {
  TWITTER
  INSTAGRAM
  FACEBOOK
  TIKTOK
  PINTEREST
  THREADS
}

model SocialAccount {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        SocialPlatform
  platformUserId  String         // Platform's user ID
  username        String?
  displayName     String?
  profileImage    String?
  
  // OAuth tokens (encrypted)
  accessToken     String         @db.Text
  refreshToken    String?        @db.Text
  tokenExpiresAt  DateTime?
  
  // Platform-specific data
  platformData    Json?          // Additional platform-specific info
  
  // Status
  isActive        Boolean        @default(true)
  lastSyncedAt    DateTime?
  
  // Relations
  posts           PostAccount[]
  analytics       AccountAnalytics[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([userId, platform, platformUserId])
  @@map("social_accounts")
}

// ===========================================
// Posts
// ===========================================

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

model Post {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Content
  content         String?       @db.Text
  platformContent Json?         // Platform-specific content variations
  
  // Status & Scheduling
  status          PostStatus    @default(DRAFT)
  scheduledAt     DateTime?
  publishedAt     DateTime?
  
  // Error handling
  errorMessage    String?       @db.Text
  retryCount      Int           @default(0)
  
  // Source
  templateId      String?
  template        Template?     @relation(fields: [templateId], references: [id])
  
  // Relations
  media           PostMedia[]
  accounts        PostAccount[]
  analytics       PostAnalytics?
  platformPosts   PlatformPost[]
  
  // Metadata
  category        String?       // promotional, educational, personal, etc.
  tags            String[]      @default([])
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, status])
  @@index([userId, scheduledAt])
  @@map("posts")
}

// Post-to-Account junction (which platforms to post to)
model PostAccount {
  id             String        @id @default(cuid())
  postId         String
  post           Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId      String
  account        SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  // Platform-specific content override
  content        String?       @db.Text
  
  // Manual posting (for Threads, etc.)
  isManual       Boolean       @default(false)
  manualStatus   ManualStatus?
  manualPostedAt DateTime?
  manualPostUrl  String?
  
  createdAt      DateTime      @default(now())

  @@unique([postId, accountId])
  @@map("post_accounts")
}

enum ManualStatus {
  PENDING
  COPIED
  OPENED
  POSTED
  SKIPPED
}

// Actual published posts on platforms
model PlatformPost {
  id             String   @id @default(cuid())
  postId         String
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId      String
  account        SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  // Platform data
  platformPostId String?  // ID on the platform
  postUrl        String?  // Link to the post
  
  // Status
  status         PostStatus @default(PUBLISHING)
  publishedAt    DateTime?
  errorMessage   String?  @db.Text
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([postId, accountId])
  @@map("platform_posts")
}

// ===========================================
// Media
// ===========================================

model Media {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // File info
  filename      String   // Stored filename
  originalName  String   // Original upload name
  mimeType      String
  size          Int      // Bytes
  width         Int?
  height        Int?
  
  // Storage
  path          String   // Local path or S3 key
  url           String   // Public URL
  
  // Metadata
  altText       String?
  category      String?
  tags          String[] @default([])
  
  // Relations
  posts         PostMedia[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("media")
}

model PostMedia {
  id       String  @id @default(cuid())
  postId   String
  post     Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  mediaId  String
  media    Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  order    Int     @default(0) // Order in the post
  
  @@unique([postId, mediaId])
  @@map("post_media")
}

// ===========================================
// Templates
// ===========================================

model Template {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  content     String   @db.Text
  
  // Variables that can be replaced
  variables   Json?    // Array of { name: string, description: string, default?: string }
  
  // Metadata
  category    String?
  isFavorite  Boolean  @default(false)
  useCount    Int      @default(0)
  
  // Relations
  posts       Post[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("templates")
}

// ===========================================
// Analytics
// ===========================================

model PostAnalytics {
  id            String   @id @default(cuid())
  postId        String   @unique
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  accountId     String
  account       SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  
  // Engagement
  likes         Int      @default(0)
  comments      Int      @default(0)
  shares        Int      @default(0)
  saves         Int      @default(0)
  
  // Reach
  views         Int      @default(0)
  impressions   Int      @default(0)
  reach         Int      @default(0)
  
  // Video-specific
  videoViews    Int?
  avgWatchTime  Float?
  
  // Platform-specific
  platformData  Json?
  
  recordedAt    DateTime @default(now())
  
  @@map("post_analytics")
}

model AccountAnalytics {
  id            String   @id @default(cuid())
  accountId     String
  account       SocialAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  
  // Aggregated metrics
  totalPosts    Int      @default(0)
  totalLikes    Int      @default(0)
  totalComments Int      @default(0)
  totalShares   Int      @default(0)
  totalReach    Int      @default(0)
  totalViews    Int      @default(0)
  
  // Follower stats
  followers     Int?
  following     Int?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([accountId, date])
  @@map("account_analytics")
}