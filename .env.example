# ===========================================
# BEAN - Social Media Post Manager
# ===========================================
# Copy this file to .env.local and fill in your values

# App Configuration
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-secure-random-string-at-least-32-chars

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/bean"

# ===========================================
# SOCIAL PLATFORM OAUTH (Bring Your Own Keys)
# ===========================================
# Create developer apps on each platform and enter credentials below

# Twitter/X (Requires Basic Tier - $100/mo for posting)
# https://developer.twitter.com/
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Instagram (via Meta/Facebook Developer Portal)
# https://developers.facebook.com/
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Facebook (via Meta Developer Portal)
# https://developers.facebook.com/
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# TikTok (via TikTok for Developers)
# https://developers.tiktok.com/
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Pinterest (via Pinterest Developer Portal)
# https://developers.pinterest.com/
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# Threads (Limited API - Manual posting only)
THREADS_ENABLED=true

# ===========================================
# AI PROVIDERS (Configure at least one)
# ===========================================

# OpenAI (Recommended for best results)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Ollama (Free, Local - No API key needed)
# Install from https://ollama.ai
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Zhipu GLM (智谱AI)
# https://open.bigmodel.cn/
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4

# Anthropic (Optional)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-opus-20240229

# Default AI Provider: openai, ollama, zhipu, anthropic
DEFAULT_AI_PROVIDER=ollama

# ===========================================
# STORAGE
# ===========================================

# Local storage (default)
UPLOAD_DIR=./uploads

# Or S3-compatible storage (uncomment to use)
# STORAGE_PROVIDER=s3
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

# ===========================================
# OPTIONAL: BEAN CLOUD MODE (Future)
# ===========================================
# Use Bean's hosted OAuth service
# BEAN_MODE=self-hosted
# BEAN_CLOUD_URL=https://api.bean.social
# BEAN_CLOUD_API_KEY=